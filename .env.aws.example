# Exemplo de .env para rodar o painel e o Wings na AWS (EC2).
# Copie para .env na EC2: cp .env.aws.example .env
#
# Security Group (EC2): permita entrada em 22 (SSH), 80 (HTTP), 443 (HTTPS),
# 8080 (Wings API), 2022 (SFTP) e portas dos jogos (ex.: 27015 para CS2).

# Banco de dados (MariaDB)
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# Painel – use a URL pública (IP da EC2 ou domínio com HTTPS)
APP_URL=https://painel.seudominio.com
APP_SERVICE_AUTHOR=admin@seudominio.com

# Wings – preencha depois de criar o node no painel (Admin → Nodes → [node] → Configuration).
# Na mesma EC2 use WINGS_API_HOST=http://panel (rede interna).
# Em duas EC2 use o IP privado do painel, ex.: WINGS_API_HOST=http://10.0.1.10
WINGS_API_HOST=http://panel
WINGS_TOKEN_ID=
WINGS_SYSTEM_TOKEN=
